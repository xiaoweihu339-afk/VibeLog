{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibelog.local/schemas/vibelog-0.2-draft.json",
  "title": "VibeLog",
  "type": "object",
  "required": [
    "schema",
    "title",
    "one_line_vibe",
    "stage",
    "visibility",
    "creation_mode",
    "process_level",
    "current_idea",
    "implementation_status",
    "validation_design",
    "handoff_state",
    "vibe_progress"
  ],
  "properties": {
    "schema": {
      "enum": ["vibelog@0.1", "vibelog@0.2-draft"]
    },
    "title": {
      "type": "string"
    },
    "one_line_vibe": {
      "type": "string"
    },
    "stage": {
      "enum": ["idea", "brief", "prototype", "mvp", "beta", "shipped", "paused", "abandoned"]
    },
    "visibility": {
      "enum": ["private", "public_idea", "public_progress", "public_product"]
    },
    "code_visibility": {
      "enum": ["hidden", "open_source", "team_only", "not_applicable"]
    },
    "prompt_visibility": {
      "enum": ["hidden", "summary", "full"]
    },
    "collaboration_status": {
      "enum": [
        "closed",
        "open_to_feedback",
        "looking_for_builder",
        "looking_for_designer",
        "looking_for_partner",
        "looking_for_users",
        "looking_for_investment"
      ]
    },
    "creation_mode": {
      "enum": [
        "human_led_ai_assisted",
        "human_ai_co_created",
        "agent_led_human_approved",
        "fully_agent_built",
        "multi_human_multi_agent",
        "unknown"
      ]
    },
    "process_level": {
      "enum": ["minimal", "core", "full"]
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "current_idea": {
      "type": "string"
    },
    "vibe_intake": {
      "type": "object",
      "properties": {
        "problem": { "type": "string" },
        "target_users": { "type": "array", "items": { "type": "string" } },
        "desired_outcome": { "type": "string" },
        "current_stage": { "type": "string" },
        "tools_or_agents": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "idea_expansion": {
      "type": "object",
      "properties": {
        "product_hypothesis": { "type": "string" },
        "problem": { "type": "string" },
        "target_users": { "type": "array", "items": { "type": "string" } },
        "why_it_matters": { "type": "string" },
        "core_value": { "type": "string" },
        "core_features": { "type": "array", "items": { "type": "string" } },
        "use_cases": { "type": "array", "items": { "type": "string" } },
        "non_goals": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "idea_evolution": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "type": { "enum": ["initial", "expansion", "pivot", "refinement", "removal", "scope_change"] },
          "before": { "type": "string" },
          "after": { "type": "string" },
          "reason": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "type", "after"],
        "additionalProperties": false
      }
    },
    "scope_plan": {
      "type": "object",
      "properties": {
        "current_goal": { "type": "string" },
        "in_scope": { "type": "array", "items": { "type": "string" } },
        "out_of_scope": { "type": "array", "items": { "type": "string" } },
        "acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "planned_steps": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "decision": { "type": "string" },
          "why": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "decision"],
        "additionalProperties": false
      }
    },
    "human_in_the_loop": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "type": {
            "enum": [
              "direction",
              "scope",
              "taste",
              "tradeoff",
              "approval",
              "rejection",
              "risk",
              "naming",
              "prioritization",
              "privacy",
              "release"
            ]
          },
          "human_input": { "type": "string" },
          "agent_proposal": { "type": "string" },
          "final_decision": { "type": "string" },
          "why_it_mattered": { "type": "string" },
          "impact": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "type", "human_input", "final_decision"],
        "additionalProperties": false
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_status": {
      "type": "object",
      "required": ["current_state", "completed", "in_progress", "pending", "blocked", "next_actions"],
      "properties": {
        "current_state": { "type": "string" },
        "completed": { "type": "array", "items": { "type": "string" } },
        "in_progress": { "type": "array", "items": { "type": "string" } },
        "pending": { "type": "array", "items": { "type": "string" } },
        "blocked": { "type": "array", "items": { "type": "string" } },
        "next_actions": { "type": "array", "items": { "type": "string" } },
        "important_context_for_next_agent": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "validation_design": {
      "type": "object",
      "required": ["success_criteria", "core_user_paths", "manual_test_steps", "automated_test_strategy"],
      "properties": {
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "core_user_paths": { "type": "array", "items": { "type": "string" } },
        "manual_test_steps": { "type": "array", "items": { "type": "string" } },
        "automated_test_strategy": { "type": "string" },
        "edge_cases": { "type": "array", "items": { "type": "string" } },
        "regression_points": { "type": "array", "items": { "type": "string" } },
        "risks_safety_privacy": { "type": "array", "items": { "type": "string" } },
        "owner": { "type": "string" }
      },
      "additionalProperties": false
    },
    "verification_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "type": {
            "enum": [
              "command_output",
              "test_result",
              "screenshot",
              "demo",
              "manual_qa",
              "review",
              "deployment"
            ]
          },
          "summary": { "type": "string" },
          "evidence_ref": { "type": "string" },
          "result": { "enum": ["passed", "failed", "partial", "not_run"] },
          "residual_risk": { "type": "string" },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "type", "summary", "result"],
        "additionalProperties": false
      }
    },
    "project_context": {
      "type": "object",
      "properties": {
        "repo_url": { "type": "string" },
        "workspace_path": { "type": "string" },
        "important_files": { "type": "array", "items": { "type": "string" } },
        "run_commands": { "type": "array", "items": { "type": "string" } },
        "test_commands": { "type": "array", "items": { "type": "string" } },
        "known_issues": { "type": "array", "items": { "type": "string" } },
        "do_not_change": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "code_repositories": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "provider": {
            "enum": ["github", "gitlab", "bitbucket", "local", "vibehub_future", "other"]
          },
          "url": { "type": "string" },
          "remote_name": { "type": "string" },
          "default_branch": { "type": "string" },
          "current_branch": { "type": "string" },
          "latest_commit_sha": { "type": "string" },
          "sync_status": {
            "enum": ["unlinked", "local_only", "linked", "pushed", "mirrored", "hosted"]
          },
          "code_visibility": {
            "enum": ["hidden", "open_source", "team_only", "not_applicable"]
          },
          "demo_url": { "type": "string" },
          "artifact_urls": {
            "type": "array",
            "items": { "type": "string" }
          },
          "linked_commits": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "sha": { "type": "string" },
                "branch": { "type": "string" },
                "message": { "type": "string" },
                "timestamp": { "type": "string" },
                "summary": { "type": "string" },
                "vibelog_entry_ref": { "type": "string" }
              },
              "required": ["sha"],
              "additionalProperties": false
            }
          },
          "notes": { "type": "string" }
        },
        "required": ["provider"],
        "additionalProperties": false
      }
    },
    "artifact_index": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "enum": [
              "code_repo",
              "demo",
              "design",
              "document",
              "screenshot",
              "video",
              "test_output",
              "release",
              "dataset",
              "prompt_library",
              "agent_config",
              "other"
            ]
          },
          "name": { "type": "string" },
          "ref": { "type": "string" },
          "visibility": { "enum": ["hidden", "private", "team_only", "public"] },
          "notes": { "type": "string" }
        },
        "required": ["type", "name", "ref"],
        "additionalProperties": false
      }
    },
    "execution_prompts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "agent_or_tool": { "type": "string" },
          "prompt_type": { "enum": ["build", "refactor", "debug", "test", "design", "docs", "deploy", "inspect", "research"] },
          "prompt_visibility": { "enum": ["hidden", "summary", "full"] },
          "recording_mode": { "enum": ["exact", "redacted", "reconstructed", "summary_only"] },
          "prompt_summary": { "type": "string" },
          "prompt_text": { "type": "string" },
          "result": { "type": "string" },
          "reuse_notes": { "type": "string" }
        },
        "required": ["timestamp", "agent_or_tool", "prompt_type", "prompt_visibility", "recording_mode", "prompt_summary", "prompt_text"],
        "additionalProperties": false
      }
    },
    "development_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "type": { "enum": ["feature", "bugfix", "refactor", "test", "docs", "chore", "release", "deployment", "config"] },
          "summary": { "type": "string" },
          "files_changed": { "type": "array", "items": { "type": "string" } },
          "artifacts_changed": { "type": "array", "items": { "type": "string" } },
          "details": { "type": "string" },
          "bug_symptom": { "type": "string" },
          "root_cause": { "type": "string" },
          "fix": { "type": "string" },
          "verification": { "type": "string" },
          "follow_up": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "type", "summary"],
        "additionalProperties": false
      }
    },
    "bugfix_incident_log": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "symptom": { "type": "string" },
          "root_cause": { "type": "string" },
          "fix": { "type": "string" },
          "affected_area": { "type": "string" },
          "verification": { "type": "string" },
          "prevention_or_follow_up": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "symptom", "fix"],
        "additionalProperties": false
      }
    },
    "handoff_state": {
      "type": "object",
      "required": ["current_state", "completed", "in_progress", "pending", "blockers", "next_actions", "context_for_next_agent"],
      "properties": {
        "current_state": { "type": "string" },
        "completed": { "type": "array", "items": { "type": "string" } },
        "in_progress": { "type": "array", "items": { "type": "string" } },
        "pending": { "type": "array", "items": { "type": "string" } },
        "blockers": { "type": "array", "items": { "type": "string" } },
        "next_actions": { "type": "array", "items": { "type": "string" } },
        "context_for_next_agent": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "public_private_projection": {
      "type": "object",
      "properties": {
        "public_summary": { "type": "string" },
        "code_visibility": { "enum": ["hidden", "open_source", "team_only", "not_applicable"] },
        "prompt_visibility": { "enum": ["hidden", "summary", "full"] },
        "collaboration_status": {
          "enum": [
            "closed",
            "open_to_feedback",
            "looking_for_builder",
            "looking_for_designer",
            "looking_for_partner",
            "looking_for_users",
            "looking_for_investment"
          ]
        },
        "remix_permission": { "enum": ["not_allowed", "allowed_with_attribution", "allowed", "unknown"] },
        "license_or_usage_note": { "type": "string" }
      },
      "additionalProperties": false
    },
    "branch_remix_readiness": {
      "type": "object",
      "properties": {
        "remix_allowed": { "type": "boolean" },
        "what_can_be_reused": { "type": "array", "items": { "type": "string" } },
        "what_should_not_be_reused": { "type": "array", "items": { "type": "string" } },
        "suggested_contribution_areas": { "type": "array", "items": { "type": "string" } },
        "attribution_requirements": { "type": "string" }
      },
      "additionalProperties": false
    },
    "vibe_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "timestamp": { "type": "string" },
          "stage": { "enum": ["idea", "brief", "prototype", "mvp", "beta", "shipped", "paused", "abandoned"] },
          "what_happened": { "type": "string" },
          "tools_used": { "type": "array", "items": { "type": "string" } },
          "problems": { "type": "array", "items": { "type": "string" } },
          "next": { "type": "array", "items": { "type": "string" } },
          "source": { "type": "string" },
          "confidence": { "enum": ["high", "medium", "low"] }
        },
        "required": ["timestamp", "stage", "what_happened"],
        "additionalProperties": false
      }
    },
    "public_summary": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
